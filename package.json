{
  "name": "nepali-address",
  "version": "0.1.1",
  "description": "The definitive, type-safe dataset of Nepal's administrative divisions with English and Nepali support.",
  "keywords": [
    "nepal",
    "address",
    "province",
    "district",
    "municipality",
    "wards"
  ],
  "license": "MIT",
  "author": "hoasloymas",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "prepublishOnly": "npm test && npm run build",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:clean": "rm -rf docs && typedoc"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2"
  }
}
